rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the Cloud Function (admin SDK) can read/write.
    // Client-side access is blocked entirely.
    match /users/{telegramId} {
      allow read, write: if false;
    }

    // Conversations: same — server-side only.
    match /conversations/{telegramId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
